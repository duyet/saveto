{
	"name": "saveto",
	"version": "0.1.0",
	"description": "Saveto.co by Koa",
	"main": "app.js",
	"scripts": {
		"start": "./node_modules/.bin/nodemon app.js",
		"gendoc": "./node_modules/.bin/jsdoc --configure jsdoc.json ./app app.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"snyk-protect": "snyk protect",
		"prepublish": "npm run snyk-protect",
		"build": "tsc",
		"build:worker": "wrangler deploy --dry-run --outdir=dist",
		"type-check": "tsc --noEmit",
		"lint": "tsc --noEmit",
		"cf:dev": "wrangler dev",
		"cf:deploy": "wrangler deploy",
		"cf:d1:create": "wrangler d1 create saveto-db",
		"cf:d1:migrate": "wrangler d1 execute saveto-db --file=./schema.sql",
		"cf:d1:query": "wrangler d1 execute saveto-db --command",
		"cf:kv:create": "wrangler kv:namespace create CACHE",
		"cf:pages:deploy": "wrangler pages deploy ./public --project-name saveto"
	},
	"keywords": [
		"Quick",
		"shorten",
		"link",
		"jslab",
		"duyetdev",
		"saveto",
		"saveto.co"
	],
	"homepage": "https://saveto.co",
	"repository": "git://github.com/saveto-co/saveto.git",
	"author": "Van-Duyet Le <me@duyetdev.com>",
	"license": "MIT",
	"dependencies": {
		"bcrypt-nodejs": "0.0.3",
		"co": "^4.6.0",
		"co-event": "^0.1.0",
		"drizzle-orm": "^0.30.0",
		"handlebars-intl": "^1.1.2",
		"highlight.js": "^11.0.0",
		"koa": "^3.0.0",
		"koa-flash": "^1.0.0",
		"koa-hbs": "^0.9.0",
		"koa-helmet": "^9.0.0",
		"koa-passport": "^6.0.0",
		"koa-router": "^14.0.0",
		"koa-session": "^7.0.0",
		"koa-static-cache": "^5.0.0",
		"koa-static-folder": "^0.1.6",
		"marked": "^16.0.0",
		"marked-sanitized": "^1.0.0",
		"mathjs": "^15.0.0",
		"md5": "^2.0.0",
		"passport-github": "^1.1.0",
		"passport-local": "^1.0.0",
		"passport-remember-me": "0.0.1",
		"pmx": "^1.0.0",
		"randomstring": "^1.1.4",
		"slug": "^11.0.0",
		"validator": "^13.0.0",
		"snyk": "^1.41.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.0.0",
		"@types/koa": "^2.14.0",
		"@types/koa-router": "^7.4.8",
		"@types/koa-session": "^6.4.5",
		"@types/node": "^20.0.0",
		"@vitest/coverage-v8": "^1.6.0",
		"@vitest/ui": "^1.6.0",
		"drizzle-kit": "^0.20.0",
		"jsdoc": "4.0.5",
		"nodemon": "3.1.10",
		"tsx": "^4.7.0",
		"typescript": "^5.3.0",
		"uglify-js": "3.19.3",
		"vitest": "^1.6.0",
		"wrangler": "^3.0.0"
	},
	"snyk": true
}
